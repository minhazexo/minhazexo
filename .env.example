# Environment Variables
# Copy this file to .env.local and fill in values

# --- Email Service (for Contact Form) ---
# Currently, the contact form logs submissions to console.
# To send actual emails, integrate with a service like Resend or SendGrid.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_EMAIL=mehrabhossain7102@gmail.com

# --- Site URL (used for sitemaps, OG metadata) ---
# Override for local development; defaults to https://mehrabhossain.dev
# NEXT_PUBLIC_SITE_URL=http://localhost:4000

# --- Analytics ---
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
